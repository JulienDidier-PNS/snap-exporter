{
  "name": "snap-exporter",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "npx electron-builder build --mac",
    "build:win": "npx electron-builder build --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.snap.exporter",
    "productName": "SnapExporter",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "build/**/*",
      "node_modules/**/*",
      "front/out/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend/dist",
        "filter": [
          "snap-exporter-backend",
          "snap-exporter-backend.exe"
        ]
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JulienDidier-PNS/snap-exporter.git"
  },
  "keywords": [],
  "author": "JulienD.",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/JulienDidier-PNS/snap-exporter/issues"
  },
  "homepage": "https://github.com/JulienDidier-PNS/snap-exporter#readme",
  "devDependencies": {
    "electron": "39.2.7",
    "electron-builder": "26.4.0"
  },
  "dependencies": {
    "electron-serve": "3.0.0",
    "jszip": "3.10.1"
  }
}
